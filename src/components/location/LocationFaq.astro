---
interface Props {
  faqs: { q: string; a: string }[];
  heading?: string;
}
const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;
---

<section class="section-white">
  <div class="container content-narrow">
    <h2 class="faq-title">{heading}</h2>
    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
