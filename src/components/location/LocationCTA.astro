---
import type { Place } from '../../data/places';
import { COMPARE_PLANS_URL, CONTACT_URL, PHONE_TEL, PHONE_DISPLAY } from '../../consts';

interface Props {
  place: Place;
}
const { place } = Astro.props;
---

<section class="final-cta">
  <div class="container">
    <h2>Local Medicare help in {place.name}</h2>
    <p>Bret Swope is a licensed Utah Medicare agent &mdash; no bots, no pressure, no cost to you. Get clear answers or compare plans on your own.</p>
    <div class="cta-buttons">
      <a href={CONTACT_URL} class="btn btn-primary btn-lg">Talk to Bret</a>
      <a href={COMPARE_PLANS_URL} class="btn btn-outline btn-lg" target="_blank" rel="noopener">Compare Plans Online</a>
      <a href={PHONE_TEL} class="btn btn-outline btn-lg">Call {PHONE_DISPLAY}</a>
    </div>
  </div>
</section>
