---
// Location hub template (P2.5): copy from the location shared module — one
// set of {placeName} templates serves every place in every locale. The Place
// derives from the URL, so the same component renders master routes and the
// [locale] dynamic route. CMS figures interpolate from figures.ts (§6.8).
import MainLayout from '../../layouts/MainLayout.astro';
import LocationTools from './LocationTools.astro';
import LocationFaq from './LocationFaq.astro';
import LocationCTA from './LocationCTA.astro';
import LocationBreadcrumb from './LocationBreadcrumb.astro';
import { getLocationCopy, hubHref, pageHref, parentStateHub, placeFromSlug, type Crumb } from '../../data/places';
import { PHONE_DISPLAY } from '../../consts';
import { CURRENT } from '../../data/figures';
import { DEFAULT_LOCALE, getLangFromUrl, getLocaleMeta, pageSlugFromUrl, t } from '../../i18n/locales';
import { SITE_ORIGIN, hreflangAlternates, interp, localizeHref } from '../../i18n/content';

const lang = getLangFromUrl(Astro.url);
const slug = pageSlugFromUrl(Astro.url);
const { place } = placeFromSlug(slug)!;
const n = place.name;
const copy = getLocationCopy(lang);
const c = copy.overview;
const shell = copy.shell;
const usd = (v: number) => `$${v.toLocaleString('en-US')}`;
const vars = { placeName: n, year: CURRENT.year, partDAnnualCap: usd(CURRENT.partD.annualCap), phone: PHONE_DISPLAY };
const canonicalEn = hubHref(place);
const canonical = lang === DEFAULT_LOCALE ? canonicalEn : `/${lang}${canonicalEn}`;
const alternates = hreflangAlternates(slug);
const SITE = SITE_ORIGIN;

const faqs = c.faqs.map((f) => ({ q: interp(f.q, vars), a: interp(f.a, vars) }));
const faqLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const crumbs: Crumb[] = [{ name: t('nav.home', lang), href: localizeHref('/', lang) }];
const parent = parentStateHub(place);
if (place.kind === 'county' && place.stateName && parent) {
  crumbs.push({ name: interp(shell.crumbPlace, { placeName: place.stateName }), href: localizeHref(parent, lang) });
}
crumbs.push({ name: interp(shell.crumbPlace, { placeName: n }), href: canonical });
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((cr, i) => ({ '@type': 'ListItem', position: i + 1, name: cr.name, item: `${SITE}${cr.href}` })),
};
---

<MainLayout
  title={interp(c.title, vars)}
  description={interp(c.description, vars)}
  canonical={canonical}
  pageType="Guide"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.code} href={a.href} />)}
    {lang !== DEFAULT_LOCALE && <meta property="og:locale" content={getLocaleMeta(lang).ogLocale} />}
  </Fragment>

  <section class="page-header">
    <div class="container">
      <LocationBreadcrumb crumbs={crumbs} />
      <h1>{interp(c.h1, vars)}</h1>
      <p class="lede" set:html={interp(c.ledeHtml, vars)}></p>
    </div>
  </section>

  <section class="section-white">
    <div class="container content-narrow">
      <h2>{interp(c.s1H2 as string, vars)}</h2>
      <p set:html={interp(c.s1P1Html as string, vars)}></p>
      <p>{interp(c.s1P2 as string, vars)}</p>
      <ul>
        {(c.s1ItemsHtml as string[]).map((item) => <li set:html={item} />)}
      </ul>
      <p set:html={interp(c.s1P3Html as string, vars)}></p>
    </div>
  </section>

  <section class="section-tinted">
    <div class="container content-narrow">
      <h2>{interp(c.maH2 as string, vars)}</h2>
      <p set:html={interp(c.maPHtml as string, vars)}></p>
      <p><a href={localizeHref(pageHref(place, 'medicare-advantage'), lang)}><strong set:html={interp(c.maLinkLabelHtml as string, vars)} /></a></p>

      <h2>{interp(c.msH2 as string, vars)}</h2>
      <p set:html={interp(c.msPHtml as string, vars)}></p>
      <p><a href={localizeHref(pageHref(place, 'medicare-supplement'), lang)}><strong set:html={interp(c.msLinkLabelHtml as string, vars)} /></a></p>

      <h2>{interp(c.pdH2 as string, vars)}</h2>
      <p set:html={interp(c.pdPHtml as string, vars)}></p>
      <p><a href={localizeHref(pageHref(place, 'part-d'), lang)}><strong set:html={interp(c.pdLinkLabelHtml as string, vars)} /></a></p>
    </div>
  </section>

  <section class="section-white">
    <div class="container content-narrow">
      <h2>{interp(c.t65H2 as string, vars)}</h2>
      <p set:html={interp(c.t65P1Html as string, vars)}></p>
      <p set:html={interp(c.t65P2Html as string, vars)}></p>

      <h2>{interp(c.helpH2 as string, vars)}</h2>
      <p set:html={interp(c.helpPHtml as string, vars)}></p>
    </div>
  </section>

  <LocationTools
    tools={['eligibility', 'timeline', 'cost-estimator', 'drug-cost']}
    heading={interp(c.toolsHeading, vars)}
    sub={interp(c.toolsSub, vars)}
  />

  <LocationFaq faqs={faqs} heading={interp(c.faqHeading, vars)} />

  <LocationCTA place={place} />
</MainLayout>
