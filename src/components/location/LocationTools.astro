---
import { TOOLS } from '../../consts';

interface Props {
  tools: string[];
  heading?: string;
  sub?: string;
  tint?: boolean;
}
const { tools, heading = 'Free Medicare tools', sub, tint = true } = Astro.props;
const cards = tools.filter((k): k is keyof typeof TOOLS => k in TOOLS).map((k) => TOOLS[k]);
---

<section class={tint ? 'section-tinted' : 'section-white'}>
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Free tools</span>
      <h2>{heading}</h2>
      {sub && <p>{sub}</p>}
    </div>
    <div class="card-grid">
      {cards.map((t) => (
        <a href={t.href} class="card" style="text-decoration:none;">
          <div class="card-icon"><i class={`fa-solid ${t.icon}`} style="font-size:1.6rem"></i></div>
          <h3>{t.title}</h3>
          <p>{t.desc}</p>
          <span class="card-link">Open tool</span>
        </a>
      ))}
    </div>
  </div>
</section>
