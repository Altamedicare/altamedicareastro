---
// src/components/content/FaqCategoryPage.astro — THE shared FAQ category
// template (8 slugs × every locale from one component). Copy lives in the
// faqs shared module (src/i18n/shared/faqs/{locale}.json); the FAQPage and
// Breadcrumb JSON-LD are built from the SAME accessor that renders the
// visible page, so structured data can never drift from the content — in
// any language. The category key derives from the URL (works identically on
// the master route and the [locale] dynamic route).
import MainLayout from '../../layouts/MainLayout.astro';
import { getFaqData } from '../../data/faqs';
import { TOOLS, COMPARE_PLANS_URL, CONTACT_URL, PHONE_DISPLAY } from '../../consts';
import { DEFAULT_LOCALE, getLangFromUrl, getLocaleMeta, localizeLabel, pageSlugFromUrl, t } from '../../i18n/locales';
import { SITE_ORIGIN, getAvailableLocales, hreflangAlternates, interp, localePageHref, localizeHref } from '../../i18n/content';

const lang = getLangFromUrl(Astro.url);
const slug = pageSlugFromUrl(Astro.url); // "faq/<key>"
const key = slug.split('/')[1];
const { shell, categories } = getFaqData(lang);
const cat = categories.find((c) => c.key === key)!;
const canonical = lang === DEFAULT_LOCALE ? `/faq/${key}.html` : `/${lang}/faq/${key}.html`;
const alternates = hreflangAlternates(slug);
const SITE = SITE_ORIGIN;
const href = (h: string) => localizeHref(h, lang);
const vars = { title: cat.title, blurb: cat.blurb, count: cat.faqs.length };

// FAQPage + Breadcrumb schema built from the SAME data the page renders.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: cat.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home', lang), item: `${SITE}${localePageHref('index', lang)}` },
    { '@type': 'ListItem', position: 2, name: shell.faqCrumb, item: `${SITE}${localePageHref('faq', lang)}` },
    { '@type': 'ListItem', position: 3, name: cat.title, item: `${SITE}${canonical}` },
  ],
};
---

<MainLayout
  title={interp(shell.catTitle, vars)}
  description={interp(shell.catDescription, vars)}
  canonical={canonical}
  pageType="FAQ"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.code} href={a.href} />)}
    {lang !== DEFAULT_LOCALE && <meta property="og:locale" content={getLocaleMeta(lang).ogLocale} />}
  </Fragment>

  <section class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href={href('/')}>{t('nav.home', lang)}</a> &nbsp;&rsaquo;&nbsp; <a href={href('/faq.html')}>{shell.faqCrumb}</a> &nbsp;&rsaquo;&nbsp; {cat.title}</div>
      <h1><i class={`fa-solid ${cat.icon}`} style="margin-right:10px;color:var(--mountain-blue);"></i>{cat.title}</h1>
      <p class="lede">{cat.blurb}</p>
    </div>
  </section>

  <section class="section-white">
    <div class="container content-narrow">
      <div class="faq-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="faqFilter" placeholder={interp(shell.searchPlaceholder, vars)} aria-label={shell.filterAria} autocomplete="off" />
      </div>
      <p class="faq-resultcount" id="faqCount" aria-live="polite"></p>

      <div class="faq-list" id="faqList">
        {cat.faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="faq-answer">
              <p>{f.a}</p>
              {(f.links?.length || f.tools?.length) && (
                <div class="faq-actions">
                  {f.links?.map((l) => (
                    <a class="faq-link" href={href(l.href)}><i class="fa-solid fa-book-open"></i> {l.label}</a>
                  ))}
                  {f.tools?.filter((k) => k in TOOLS).map((k) => {
                    const tool = TOOLS[k as keyof typeof TOOLS];
                    return <a class="faq-tool" href={href(tool.href)}><i class={`fa-solid ${tool.icon}`}></i> {localizeLabel(tool.title, lang)}</a>;
                  })}
                </div>
              )}
              <div class="faq-cta">
                <a href={COMPARE_PLANS_URL} target="_blank" rel="noopener"><i class="fa-solid fa-magnifying-glass-chart"></i> {shell.compareLabel}</a>
                <span class="dot" aria-hidden="true">&middot;</span>
                <a href={href(CONTACT_URL)}><i class="fa-solid fa-comment"></i> {shell.talkLabel}</a>
              </div>
            </div>
          </details>
        ))}
      </div>

      <p class="faq-empty" id="faqEmpty" hidden set:html={shell.emptyHtml}></p>

      <div style="text-align:center; margin-top:36px;">
        <a href={href('/faq.html')} class="btn btn-outline" set:html={shell.backHtml} />
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ countOne: shell.countSingular, countMany: shell.countPlural }}>
    (function () {
      var input = document.getElementById('faqFilter');
      var items = Array.prototype.slice.call(document.querySelectorAll('#faqList .faq-item'));
      var count = document.getElementById('faqCount');
      var empty = document.getElementById('faqEmpty');
      if (!input) return;
      function apply() {
        var q = input.value.trim().toLowerCase();
        var shown = 0;
        items.forEach(function (it) {
          var match = !q || it.textContent.toLowerCase().indexOf(q) !== -1;
          it.style.display = match ? '' : 'none';
          if (match) shown++;
        });
        empty.hidden = shown > 0;
        var tpl = items.length === 1 ? countOne : countMany;
        count.textContent = q ? tpl.replace('{shown}', shown).replace('{total}', items.length) : '';
      }
      input.addEventListener('input', apply);
    })();
  </script>
</MainLayout>
