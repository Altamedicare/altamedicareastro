---
// src/components/content/ContactPage.astro — THE shared Contact template.
// Copy lives in src/i18n/content/{locale}/contact.json; presentation only.
// External-system boundaries (honest, per playbook §3): the Cal.com booking
// widget and the SunFire plan portal are English-only vendor surfaces.
import MainLayout from '../../layouts/MainLayout.astro';
import { DEFAULT_LOCALE, getLangFromUrl, getLocaleMeta } from '../../i18n/locales';
import { getPageContent, hreflangAlternates, interp, localizeHref } from '../../i18n/content';
import { COMPARE_PLANS_URL, PHONE_DISPLAY } from '../../consts';

interface ContactContent {
  page: { title: string; description: string };
  breadcrumbHtml: string;
  header: { h1: string; ledeHtml: string };
  info: {
    h3: string;
    phoneLabel: string;
    phoneHoursHtml: string;
    emailLabel: string;
    emailNote: string;
    officeLabel: string;
    officeCity: string;
    officeNote: string;
    afterHeading: string;
    afterTextHtml: string;
  };
  actions: {
    h3: string;
    ledeHtml: string;
    callTitle: string;
    callSubHtml: string;
    callLabel: string;
    emailTitle: string;
    emailSub: string;
    emailLabel: string;
    bookTitle: string;
    bookSub: string;
    bookLabel: string;
    browseTitle: string;
    browseSubHtml: string;
    browseLabel: string;
  };
  cta: { h2Html: string; textHtml: string; scheduleLabel: string; callLabel: string };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<ContactContent>('contact', lang);
const vars = { phone: PHONE_DISPLAY };
const canonical = lang === DEFAULT_LOCALE ? '/contact.html' : `/${lang}/contact.html`;
const alternates = hreflangAlternates('contact');
---

<MainLayout
  title={c.page.title}
  description={interp(c.page.description, vars)}
  canonical={canonical}
>
  <Fragment slot="head">
    {alternates.map((a) => <link rel="alternate" hreflang={a.code} href={a.href} />)}
    {lang !== DEFAULT_LOCALE && <meta property="og:locale" content={getLocaleMeta(lang).ogLocale} />}
  </Fragment>

<section class="page-header">
  <div class="container">
    <div class="breadcrumb" set:html={c.breadcrumbHtml}></div>
    <h1>{c.header.h1}</h1>
    <p class="lede" set:html={c.header.ledeHtml}></p>
  </div>
</section>

<section class="section-white">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <h3>{c.info.h3}</h3>

        <div class="contact-method">
          <div class="icon-circle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <strong>{c.info.phoneLabel}</strong>
            <a href="tel:4352925548">(435) 292-5548</a>
            <p style="margin:4px 0 0; color:var(--text-muted); font-size:0.92rem;" set:html={c.info.phoneHoursHtml}></p>
          </div>
        </div>

        <div class="contact-method">
          <div class="icon-circle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
          </div>
          <div>
            <strong>{c.info.emailLabel}</strong>
            <a href="mailto:bret@altahealthins.com">bret@altahealthins.com</a>
            <p style="margin:4px 0 0; color:var(--text-muted); font-size:0.92rem;">{c.info.emailNote}</p>
          </div>
        </div>

        <div class="contact-method">
          <div class="icon-circle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <strong>{c.info.officeLabel}</strong>
            <p style="margin:0;">{c.info.officeCity}</p>
            <p style="margin:4px 0 0; color:var(--text-muted); font-size:0.92rem;">{c.info.officeNote}</p>
          </div>
        </div>

        <div style="background:var(--soft-sand); padding:24px; border-radius:var(--radius-md); margin-top:30px;">
          <strong style="color:var(--charcoal);">{c.info.afterHeading}</strong>
          <p style="margin:8px 0 0; color:var(--charcoal-soft); font-size:0.95rem;" set:html={c.info.afterTextHtml}></p>
        </div>
      </div>

      <div class="form-card contact-actions" style="margin:0;">
        <h3 style="margin-bottom:8px;">{c.actions.h3}</h3>
        <p style="margin:0 0 26px; color:var(--charcoal-soft);" set:html={c.actions.ledeHtml}></p>

        <div class="contact-action">
          <div class="icon-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div class="contact-action-text">
            <strong>{c.actions.callTitle}</strong>
            <span set:html={c.actions.callSubHtml}></span>
          </div>
          <a href="tel:4352925548" class="btn btn-primary btn-lg">{interp(c.actions.callLabel, vars)}</a>
        </div>

        <div class="contact-action">
          <div class="icon-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
          </div>
          <div class="contact-action-text">
            <strong>{c.actions.emailTitle}</strong>
            <span>{c.actions.emailSub}</span>
          </div>
          <a href="mailto:bret@altahealthins.com?subject=Medicare%20Question&body=Name%3A%0D%0APhone%3A%0D%0AQuestion%3A%0D%0A" class="btn btn-primary btn-lg">{c.actions.emailLabel}</a>
        </div>

        <div class="contact-action">
          <div class="icon-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <div class="contact-action-text">
            <strong>{c.actions.bookTitle}</strong>
            <span>{c.actions.bookSub}</span>
          </div>
          <button
            type="button"
            class="btn btn-primary btn-lg"
            data-cal-link="bret-swope-oagxvu/medicare-questions"
            data-cal-namespace="medicare-questions"
            data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true","theme":"light"}'
          >{c.actions.bookLabel}</button>
        </div>

        <div class="contact-action">
          <div class="icon-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          </div>
          <div class="contact-action-text">
            <strong>{c.actions.browseTitle}</strong>
            <span set:html={c.actions.browseSubHtml}></span>
          </div>
          <a href={COMPARE_PLANS_URL} target="_blank" rel="noopener" class="btn btn-outline btn-lg">{c.actions.browseLabel}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="final-cta">
  <div class="container">
    <h2 set:html={c.cta.h2Html}></h2>
    <p set:html={c.cta.textHtml}></p>
    <div class="cta-buttons">
      <a href={localizeHref('contact.html', lang)} class="btn btn-primary btn-lg">{c.cta.scheduleLabel}</a>
      <a href="tel:4352925548" class="btn btn-outline btn-lg">{interp(c.cta.callLabel, vars)}</a>
    </div>
  </div>
</section>

<!-- Cal.com element-click embed: powers the "Book Appointment" button above -->
<script type="text/javascript" is:inline>
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", "medicare-questions", {origin:"https://app.cal.com"});
  Cal.ns["medicare-questions"]("ui", {"theme":"light","cssVarsPerTheme":{"light":{"cal-brand":"#1b27db"}},"hideEventTypeDetails":false,"layout":"month_view"});
</script>

</MainLayout>
