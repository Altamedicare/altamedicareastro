---
// Reusable "Helpful Tools" band — links the three calculators. Used near the bottom of content pages.
const tools = [
  { href: '/medicare-eligibility-calculator.html', icon: 'fa-calendar-check', title: 'Eligibility Calculator', desc: "See when you're eligible and your enrollment dates." },
  { href: '/medicare-irmaa-calculator.html', icon: 'fa-sack-dollar', title: 'IRMAA Calculator', desc: 'Estimate your Part B & Part D premiums.' },
  { href: '/medicare-penalty-calculator.html', icon: 'fa-triangle-exclamation', title: 'Late Enrollment Penalty', desc: 'See if delaying could raise your premiums.' },
];
---

<section class="section-tinted">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Free tools</span>
      <h2>Helpful Medicare Tools</h2>
      <p>Quick, interactive calculators to help you plan with confidence.</p>
    </div>

    <div class="card-grid">
      {
        tools.map((t) => (
          <a href={t.href} class="card" style="text-decoration:none;">
            <div class="card-icon"><i class={`fa-solid ${t.icon}`} style="font-size:1.6rem"></i></div>
            <h3>{t.title}</h3>
            <p>{t.desc}</p>
            <span class="card-link">Open tool</span>
          </a>
        ))
      }
    </div>

    <div style="text-align:center; margin-top:32px;">
      <a href="/tools.html" class="btn btn-outline">See all Medicare tools</a>
    </div>
  </div>
</section>
