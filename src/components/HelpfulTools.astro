---
// Reusable "Helpful Tools" band — links the three calculators. Used near the
// bottom of content pages. Localized (P2.2): chrome text via t(), inline tool
// labels via localizeLabel (both identity for English — byte-stable), hrefs
// via localizeHref (calculators are untranslated → absolutized English URLs
// on /es/ pages, never a 404).
import { getLangFromUrl, localizeLabel, t } from '../i18n/locales';
import { localizeHref } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const tools = [
  { href: '/medicare-eligibility-calculator.html', icon: 'fa-calendar-check', title: 'Eligibility Calculator', desc: "See when you're eligible and your enrollment dates." },
  { href: '/medicare-irmaa-calculator.html', icon: 'fa-sack-dollar', title: 'IRMAA Calculator', desc: 'Estimate your Part B & Part D premiums.' },
  { href: '/medicare-penalty-calculator.html', icon: 'fa-triangle-exclamation', title: 'Late Enrollment Penalty', desc: 'See if delaying could raise your premiums.' },
];
---

<section class="section-tinted">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">{t('tools.eyebrow', lang)}</span>
      <h2>{t('tools.h2', lang)}</h2>
      <p>{t('tools.intro', lang)}</p>
    </div>

    <div class="card-grid">
      {
        tools.map((tool) => (
          <a href={localizeHref(tool.href, lang)} class="card" style="text-decoration:none;">
            <div class="card-icon"><i class={`fa-solid ${tool.icon}`} style="font-size:1.6rem"></i></div>
            <h3>{localizeLabel(tool.title, lang)}</h3>
            <p>{localizeLabel(tool.desc, lang)}</p>
            <span class="card-link">{t('tools.open', lang)}</span>
          </a>
        ))
      }
    </div>

    <div style="text-align:center; margin-top:32px;">
      <a href={localizeHref('/tools.html', lang)} class="btn btn-outline">{t('tools.seeAll', lang)}</a>
    </div>
  </div>
</section>
