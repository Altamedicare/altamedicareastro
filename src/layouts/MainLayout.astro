---
import MedicareNews from '../components/MedicareNews.astro';
import { getLangFromUrl } from '../i18n/locales';
import { localizeHref } from '../i18n/content';

interface Props {
  title: string;
  description: string;
  /** Canonical path, e.g. "/about.html" or "/" — preserves exact existing canonicals. */
  canonical: string;
  ogImage?: string;
  /** Pagefind result type/badge + filter value. */
  pageType?: string;
  /** Skip Pagefind indexing for this page (e.g. the search page itself). */
  noIndex?: boolean;
}

const { title, description, canonical, ogImage = '/images/og-image.svg', pageType = 'Guide', noIndex = false } = Astro.props;

// Locale-aware chrome: lang derives from the URL (no prop threading — playbook
// §10). Every page link routes through localizeHref(): identity for English
// (output byte-stable), absolutized/localized under /es/ where relative hrefs
// would otherwise 404. Chrome TEXT stays English until the Phase 1 chrome-
// localization milestone.
const lang = getLangFromUrl(Astro.url);
const href = (h: string) => localizeHref(h, lang);
const canonicalUrl = new URL(canonical, Astro.site).href;
const ogUrl = canonicalUrl;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'InsuranceAgency',
  name: 'AltaMedicare',
  description: 'Local Medicare guidance and prescription savings help for Utah families.',
  url: 'https://altamedicare.com/',
  telephone: '+1-435-292-5548',
  areaServed: [
    { '@type': 'City', name: 'Orem' },
    { '@type': 'City', name: 'Provo' },
    { '@type': 'City', name: 'Salt Lake City' },
    { '@type': 'City', name: 'Ogden' },
    { '@type': 'State', name: 'Utah' },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Orem',
    addressRegion: 'UT',
    addressCountry: 'US',
  },
  founder: { '@type': 'Person', name: 'Bret Swope' },
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-D6LJEQ61V0"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-D6LJEQ61V0');
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:image" content={ogImageUrl} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/styles.css?v=29" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusiness)} />
  <slot name="head" />
</head>
<body>

