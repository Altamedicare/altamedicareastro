---
// src/pages/[locale]/[...path].astro — the dynamic localized route.
// One route generates EVERY localized page: a path is emitted only for
// (locale, page) pairs whose translated JSON is committed (existence-aware —
// getLocalizedContent), so this route cannot produce a 404.
// With build.format:'file' this emits /es/about.html, matching the site's
// .html URL policy. Ported from vernalmedicareastro (see I18N-PORT-LOG.md).
//
// One shared component per extracted page (content key === slug). Entries are
// added as pages are componentized in Phase 1; until a page has both a
// committed es JSON AND an entry here, no localized route is emitted for it.
import { getLocalizedContent, getVirtualLocalizedPages } from '../../i18n/content';
import AboutPage from '../../components/content/AboutPage.astro';
import ContactPage from '../../components/content/ContactPage.astro';
import Turning65Page from '../../components/content/Turning65Page.astro';
import MedicareBasicsPage from '../../components/content/MedicareBasicsPage.astro';
import MedicareSupplementPage from '../../components/content/MedicareSupplementPage.astro';
import PrescriptionDrugPlansPage from '../../components/content/PrescriptionDrugPlansPage.astro';
import MedicareAdvantagePage from '../../components/content/MedicareAdvantagePage.astro';
import HomePage from '../../components/content/HomePage.astro';
import FaqHubPage from '../../components/content/FaqHubPage.astro';
import FaqCategoryPage from '../../components/content/FaqCategoryPage.astro';
import DrugAssistancePage from '../../components/content/DrugAssistancePage.astro';

const COMPONENTS: Record<string, (props: Record<string, never>) => unknown> = {
  'about': AboutPage,
  'contact': ContactPage,
  'turning-65': Turning65Page,
  'medicare-basics': MedicareBasicsPage,
  'medicare-supplement': MedicareSupplementPage,
  'prescription-drug-plans': PrescriptionDrugPlansPage,
  'medicare-advantage': MedicareAdvantagePage,
  'index': HomePage,
  'faq-hub': FaqHubPage,
  'faq-category': FaqCategoryPage,
  'drug-assistance': DrugAssistancePage,
};

export function getStaticPaths() {
  // DATA ONLY — getStaticPaths is extracted into an isolated prerender chunk
  // that cannot see the component imports above. Filtering on COMPONENTS here
  // throws "COMPONENTS is not defined" (playbook §6.4 gotcha). The data-side
  // filter is CONTENT_PAGES, applied inside getLocalizedContent().
  // The homepage's path is undefined so /es emits dist/es.html (URL /es.html),
  // matching localePageHref('index', locale) and the site's .html policy.
  return [
    ...getLocalizedContent().map(({ locale, page }) => ({
      params: { locale, path: page === 'index' ? undefined : page },
      props: { contentKey: page },
    })),
    // Module-driven virtual pages (P2.3): emitted only when the shared
    // module's locale JSON is committed — existence-aware like everything.
    ...getVirtualLocalizedPages().map(({ locale, slug, contentKey }) => ({
      params: { locale, path: slug },
      props: { contentKey },
    })),
  ];
}

const Page = COMPONENTS[Astro.props.contentKey];
---

<Page />
