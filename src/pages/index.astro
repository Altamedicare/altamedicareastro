        <button class="carousel-btn" id="articlesNext" aria-label="Next articles">&rarr;</button>
      </div>
    </div>

    <div class="article-track" id="articlesTrack">
      <a href="turning-65.html" class="article-card">
        <div class="article-img alt-2"><span class="article-tag">Getting Started</span></div>
        <div class="article-body">
          <div class="article-meta">5 min read</div>
