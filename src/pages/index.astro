      <div class="bret-card">
        <img src="images/BretSwope.webp" alt="Bret Swope, founder of AltaMedicare" class="bret-photo" onerror="this.style.display='none'" />
        <h3>Bret Swope</h3>
        <p class="role">Founder · Licensed Medicare Agent</p>
        <p style="color:var(--charcoal-soft);">"My goal is to make Medicare feel less confusing — so you can make confident decisions for yourself and your family. My consultations are always free."</p>
        <div class="bret-actions">
          <a href="tel:8013680700" class="btn btn-secondary">Call</a>
          <a href="sms:18013680700?body=Hi%20Bret%2C%20I%20have%20a%20question%20about%20Medicare." class="btn btn-primary">Text</a>
          <a href="contact.html" class="btn btn-outline">Schedule</a>
        </div>
        <p style="margin:14px 0 0;"><a href="about.html" style="font-weight:600;">Read Bret's full story &rarr;</a></p>
      </div>
    </div>
  </div>
</section>

<!-- ================= LATEST ARTICLES CAROUSEL ================= -->
