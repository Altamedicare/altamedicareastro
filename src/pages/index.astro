---
import MainLayout from '../layouts/MainLayout.astro';
import { COMPARE_PLANS_URL } from '../consts';
---

<MainLayout
  title={"AltaMedicare | Simple Medicare Guidance for Utah Families"}
  description={"Helping Orem and Utah residents understand Medicare, lower prescription costs, and make confident healthcare decisions. Licensed local Medicare guidance with no pressure."}
  canonical="/"
>

<!-- ================= SECTION 1: HERO ================= -->
<section class="hero">
  <!-- Auto-playing, muted, looping background reel that fills the whole section. -->
  <div class="hero-video" aria-hidden="true">
    <video autoplay muted loop playsinline preload="auto">
      <source src="https://res.cloudinary.com/dcev2u7ki/video/upload/v1781961129/DJI_Mavic_Pro_4K_-_Orem_Utah_-_Park_Vista_khUXpXJNQ54_kk8a1s.mp4" type="video/mp4" />
    </video>
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container">
    <div class="hero-inner">
      <h1>Simple Medicare Guidance for Utah Families</h1>
      <p class="subhead">
        Helping Orem and Utah residents understand Medicare, lower prescription
        costs, and make confident healthcare decisions.
      </p>
      <div class="hero-buttons">
        <a href="contact.html" class="btn btn-primary btn-lg">Schedule Free Consultation</a>
        <a href="drug-savings.html" class="btn btn-outline btn-lg">Check Prescription Costs</a>
        <a href={COMPARE_PLANS_URL} target="_blank" rel="noopener" class="btn btn-outline btn-lg">Compare Plans Online</a>
      </div>
      <a href="tel:8013680700" class="hero-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
        (801) 368-0700
      </a>
      <p class="hero-trust">
        <span class="stars" aria-hidden="true">★★★★★</span>Trusted by Utah families · Licensed · No-pressure guidance
      </p>
    </div>

    <div class="site-search">
      <label for="medicare-search" class="sr-only">Ask a Medicare question</label>
      <div class="site-search-field">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="medicare-search" autocomplete="off" placeholder="Ask a Medicare question — e.g. &ldquo;Can I keep my doctor?&rdquo;" />
      </div>
      <div class="search-examples">
        <button type="button" class="search-example" data-q="doctor">Can I keep my doctor?</button>
        <button type="button" class="search-example" data-q="enrollment when turning 65">When should I enroll?</button>
        <button type="button" class="search-example" data-q="advantage supplement">Advantage vs Supplement?</button>
      </div>
    </div>

    <div class="hero-tools">
      <span class="hero-tools-label">Free calculators</span>
      <a href="/medicare-drug-cost-calculator.html" title="Estimate prescription costs and savings opportunities.">💊 Drug Costs</a>
      <a href="/medicare-irmaa-calculator.html" title="Estimate Medicare Part B and Part D premiums using 2026 figures.">💰 IRMAA Calculator</a>
      <a href="/medicare-penalty-calculator.html" title="Estimate lifetime Medicare late enrollment penalties.">⚠️ Penalties</a>
      <a href="/medicare-eligibility-calculator.html" title="See when you qualify and your Initial Enrollment Period.">💼 Eligibility</a>
    </div>
  </div>
</section>

<!-- ================= SECTION 2: TRUST BAR ================= -->
<section class="trust-bar">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <div class="icon-circle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/></svg>
        </div>
        <h4>Licensed Utah Medicare Help</h4>
      </div>
      <div class="trust-item">
        <div class="icon-circle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h4>No-Cost Consultations</h4>
      </div>
      <div class="trust-item">
        <div class="icon-circle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h4l3-9 4 18 3-9h4"/></svg>
        </div>
        <h4>Prescription Savings Guidance</h4>
      </div>
      <div class="trust-item">
        <div class="icon-circle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
        </div>
        <h4>Annual Plan Reviews</h4>
      </div>
      <div class="trust-item">
        <div class="icon-circle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h4>Local Utah Support</h4>
      </div>
    </div>
  </div>
</section>

<!-- ================= FREE MEDICARE TOOLS ================= -->
<section class="section-tinted" id="tools">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Free Medicare tools</span>
      <h2>Free Medicare Tools</h2>
      <p>Interactive calculators and resources to help you make informed Medicare decisions.</p>
    </div>
    <div class="card-grid">
      <a href="/medicare-eligibility-calculator.html" class="card" style="text-decoration:none;">
        <div class="card-icon"><i class="fa-solid fa-calendar-check" style="font-size:1.6rem"></i></div>
        <h3>Medicare Eligibility Calculator</h3>
        <p>Find out when you qualify for Medicare and calculate your Initial Enrollment Period.</p>
        <span class="card-link">Learn More</span>
      </a>
      <a href="/medicare-irmaa-calculator.html" class="card" style="text-decoration:none;">
        <div class="card-icon"><i class="fa-solid fa-sack-dollar" style="font-size:1.6rem"></i></div>
        <h3>IRMAA Calculator</h3>
        <p>Estimate your Medicare Part B and Part D premiums using 2026 figures.</p>
        <span class="card-link">Learn More</span>
      </a>
      <a href="/medicare-penalty-calculator.html" class="card" style="text-decoration:none;">
        <div class="card-icon"><i class="fa-solid fa-triangle-exclamation" style="font-size:1.6rem"></i></div>
        <h3>Late Enrollment Penalty Calculator</h3>
        <p>Estimate lifetime Medicare penalties and understand Special Enrollment Periods.</p>
        <span class="card-link">Learn More</span>
      </a>
      <a href="/medicare-drug-cost-calculator.html" class="card" style="text-decoration:none;">
        <div class="card-icon"><i class="fa-solid fa-pills" style="font-size:1.6rem"></i></div>
        <h3>Drug Cost Calculator</h3>
        <p>Estimate prescription costs and compare savings opportunities.</p>
        <span class="card-link">Learn More</span>
      </a>
    </div>
    <div style="text-align:center; margin-top:32px;">
      <a href="/tools.html" class="btn btn-outline">See all Medicare tools</a>
    </div>
  </div>
</section>

<!-- ================= SECTION 3: SIMPLE MEDICARE EXPLANATION ================= -->
<section class="section-white">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Medicare, simplified</span>
      <h2>The Four Things Most People Need to Know</h2>
      <p>Medicare can feel overwhelming. Here's a quick, friendly overview of the main pieces — explained without jargon.</p>
    </div>

    <div class="card-grid">
      <a href="medicare-advantage.html" class="card" style="text-decoration:none;">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>Medicare Advantage</h3>
        <p>All-in-one plans with extra benefits like dental, vision, hearing, and prescription coverage.</p>
        <span class="card-link">Learn more</span>
      </a>

      <a href="medicare-supplement.html" class="card card--sage" style="text-decoration:none;">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Medicare Supplement</h3>
        <p>Lower surprise medical costs with predictable monthly premiums and broad doctor flexibility.</p>
        <span class="card-link">Learn more</span>
      </a>

      <a href="prescription-drug-plans.html" class="card card--terracotta" style="text-decoration:none;">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.5 20.5l10-10a4.95 4.95 0 10-7-7l-10 10a4.95 4.95 0 107 7z"/><path d="M8.5 8.5l7 7"/></svg>
        </div>
        <h3>Prescription Drug Plans</h3>
        <p>Help lower medication expenses with the right Part D plan for your specific drugs.</p>
        <span class="card-link">Learn more</span>
      </a>

      <a href="turning-65.html" class="card" style="text-decoration:none;">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        </div>
        <h3>Turning 65</h3>
        <p>Learn enrollment timelines, avoid penalties, and start your Medicare journey on the right foot.</p>
        <span class="card-link">Learn more</span>
      </a>
    </div>
  </div>
</section>

<!-- ================= EDUCATIONAL VIDEO CENTER ================= -->
<section class="section-tinted" id="videos">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Watch &amp; learn</span>
      <h2>Medicare, Explained in Plain English</h2>
      <p>Short, friendly videos on the questions we hear most — with a transcript for every one. Pick a topic to watch.</p>
    </div>

    <div class="video-center">
      <div class="video-topics" role="tablist" aria-label="Video topics">
        <button class="video-topic active" role="tab" aria-selected="true"
          data-title="Understanding Medicare Parts A, B, C &amp; D"
          data-desc="A 2-minute tour of the four parts of Medicare and what each one covers."
          data-video="" data-yt="UDY-pF0Yek0" data-transcript="medicare-basics.html">
          Understanding Parts A, B, C &amp; D
        </button>
        <button class="video-topic" role="tab" aria-selected="false"
          data-title="Medicare Advantage vs Supplement"
          data-desc="The real differences — networks, costs, and flexibility — so you can choose with confidence."
          data-video="" data-yt="TwwRovzjYMk" data-transcript="medicare-advantage.html">
          Medicare Advantage vs Supplement
        </button>
        <button class="video-topic" role="tab" aria-selected="false"
          data-title="When Can I Enroll?"
          data-desc="Your Initial Enrollment Period, the Annual Enrollment Period, and how to avoid penalties."
          data-video="" data-yt="Yut_rz5cifs" data-transcript="turning-65.html">
          When Can I Enroll?
        </button>
        <button class="video-topic" role="tab" aria-selected="false"
          data-title="Can I Keep My Doctor?"
          data-desc="How plan networks work and how we check that your doctors are covered before you enroll."
          data-video="" data-yt="O2F1-u58YqI" data-transcript="medicare-advantage.html">
          Can I Keep My Doctor?
        </button>
        <button class="video-topic" role="tab" aria-selected="false"
          data-title="Prescription Drug Plans"
          data-desc="How Part D works and how we match a plan to the exact medications you take."
          data-video="" data-yt="MLN3mjcvHWM" data-transcript="prescription-drug-plans.html">
          Prescription Drug Plans
        </button>
      </div>

      <div class="video-stage">
        <div class="media-card" id="videoPlayer" data-video="" data-yt="UDY-pF0Yek0" aria-label="Educational video">
          <div class="media-poster">
            <span class="media-badge">Medicare 101</span>
            <button class="media-play" type="button" aria-label="Play this video">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </button>
            <span class="media-watch"><svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M8 5v14l11-7z"/></svg> Watch the video</span>
          </div>
        </div>
        <div class="video-meta">
          <h3 id="videoTitle">Understanding Medicare Parts A, B, C &amp; D</h3>
          <p id="videoDesc">A 2-minute tour of the four parts of Medicare and what each one covers.</p>
          <div class="video-actions">
            <a id="videoTranscript" href="medicare-basics.html" class="video-transcript">Read the transcript →</a>
            <a href="sms:18013680700?body=Hi%20Bret%2C%20I%20have%20a%20question%20after%20watching%20a%20video." class="btn btn-primary">Still have a question? Text us</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ================= SECTION 4: WHY ALTAMEDICARE ================= -->
<section class="section-white">
  <div class="container">
    <div class="why-us">
      <div>
        <span class="eyebrow" style="display:inline-block; font-size:0.85rem; font-weight:600; text-transform:uppercase; letter-spacing:0.12em; color:var(--terracotta); margin-bottom:12px;">Why families choose us</span>
        <h2>Why Utah Families Choose AltaMedicare</h2>
        <p style="font-size:1.1rem; color:var(--charcoal-soft); margin-bottom:24px;">
          We believe Medicare guidance should feel calm, clear, and personal — never pushy. Here's what makes our approach different:
        </p>
        <ul class="why-us-list">
          <li><span class="check">✓</span> Personalized Medicare guidance based on your specific situation</li>
          <li><span class="check">✓</span> Simple, jargon-free explanations without sales pressure</li>
          <li><span class="check">✓</span> Help understanding and lowering prescription costs</li>
          <li><span class="check">✓</span> Annual plan reviews to make sure you're still in the right plan</li>
          <li><span class="check">✓</span> Local Utah support — we live and work where you do</li>
          <li><span class="check">✓</span> One-on-one consultations at your pace</li>
          <li><span class="check">✓</span> Educational approach — we want you to understand, not just sign</li>
        </ul>
