<!-- ================= MINI BANNER: TURNING 65 ================= -->
<section class="mini-banner">
  <div class="container">
    <div>
      <h2>Turning 65 soon?</h2>
      <p>We'll help you understand Medicare and enroll on time — no penalties, no pressure.</p>
    </div>
    <div class="mini-banner-actions">
      <a href="sms:18013680700?body=Hi%20Bret%2C%20I%27m%20turning%2065%20and%20have%20questions." class="btn btn-primary">Text Us</a>
      <a href="turning-65.html" class="btn btn-outline">Turning 65 Guide</a>
