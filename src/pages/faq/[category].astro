---
import MainLayout from '../../layouts/MainLayout.astro';
import { FAQ_CATEGORIES, getCategory } from '../../data/faqs';
import { TOOLS, COMPARE_PLANS_URL, CONTACT_URL } from '../../consts';

export function getStaticPaths() {
  return FAQ_CATEGORIES.map((c) => ({ params: { category: c.key }, props: { key: c.key } }));
}

const { key } = Astro.props;
const cat = getCategory(key)!;
const canonical = `/faq/${key}.html`;
const SITE = 'https://altamedicare.com';

// FAQPage + Breadcrumb schema built from the SAME data the page renders.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: cat.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: `${SITE}/faq.html` },
    { '@type': 'ListItem', position: 3, name: cat.title, item: `${SITE}${canonical}` },
  ],
};
---

<MainLayout
  title={`${cat.title} FAQ | Medicare Questions | AltaMedicare`}
  description={`${cat.blurb} ${cat.faqs.length} plain-English Medicare answers from a licensed Utah agent, with links to guides and calculators.`}
  canonical={canonical}
  pageType="FAQ"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <section class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> &nbsp;&rsaquo;&nbsp; <a href="/faq.html">FAQ</a> &nbsp;&rsaquo;&nbsp; {cat.title}</div>
      <h1><i class={`fa-solid ${cat.icon}`} style="margin-right:10px;color:var(--mountain-blue);"></i>{cat.title}</h1>
      <p class="lede">{cat.blurb}</p>
    </div>
  </section>

  <section class="section-white">
    <div class="container content-narrow">
      <div class="faq-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="faqFilter" placeholder={`Search ${cat.faqs.length} ${cat.title} questions…`} aria-label="Filter questions" autocomplete="off" />
      </div>
      <p class="faq-resultcount" id="faqCount" aria-live="polite"></p>

      <div class="faq-list" id="faqList">
        {cat.faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <div class="faq-answer">
              <p>{f.a}</p>
              {(f.links?.length || f.tools?.length) && (
                <div class="faq-actions">
                  {f.links?.map((l) => (
                    <a class="faq-link" href={l.href}><i class="fa-solid fa-book-open"></i> {l.label}</a>
                  ))}
                  {f.tools?.filter((k) => k in TOOLS).map((k) => {
                    const t = TOOLS[k as keyof typeof TOOLS];
                    return <a class="faq-tool" href={t.href}><i class={`fa-solid ${t.icon}`}></i> {t.title}</a>;
                  })}
                </div>
              )}
              <div class="faq-cta">
                <a href={COMPARE_PLANS_URL} target="_blank" rel="noopener"><i class="fa-solid fa-magnifying-glass-chart"></i> Compare plans online</a>
                <span class="dot" aria-hidden="true">&middot;</span>
                <a href={CONTACT_URL}><i class="fa-solid fa-comment"></i> Talk to Bret</a>
              </div>
            </div>
          </details>
        ))}
      </div>

      <p class="faq-empty" id="faqEmpty" hidden>No questions match that search. Try fewer words, or <a href="/contact.html">ask Bret directly</a>.</p>

      <div style="text-align:center; margin-top:36px;">
        <a href="/faq.html" class="btn btn-outline">&larr; All FAQ topics</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var input = document.getElementById('faqFilter');
      var items = Array.prototype.slice.call(document.querySelectorAll('#faqList .faq-item'));
      var count = document.getElementById('faqCount');
      var empty = document.getElementById('faqEmpty');
      if (!input) return;
      function apply() {
        var q = input.value.trim().toLowerCase();
        var shown = 0;
        items.forEach(function (it) {
          var match = !q || it.textContent.toLowerCase().indexOf(q) !== -1;
          it.style.display = match ? '' : 'none';
          if (match) shown++;
        });
        empty.hidden = shown > 0;
        count.textContent = q ? (shown + ' of ' + items.length + ' question' + (items.length === 1 ? '' : 's')) : '';
      }
      input.addEventListener('input', apply);
    })();
  </script>
</MainLayout>
