---
// Thin master wrapper — one shared component renders all 8 category pages
// (src/components/content/FaqCategoryPage.astro; key derives from the URL).
import FaqCategoryPage from '../../components/content/FaqCategoryPage.astro';
import { FAQ_CATEGORIES } from '../../data/faqs';

export function getStaticPaths() {
  return FAQ_CATEGORIES.map((c) => ({ params: { category: c.key } }));
}
---

<FaqCategoryPage />
