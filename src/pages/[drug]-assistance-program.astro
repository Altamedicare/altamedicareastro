---
// Thin master wrapper — one shared component renders every drug landing page
// (src/components/content/DrugAssistancePage.astro; slug derives from URL).
import DrugAssistancePage from '../components/content/DrugAssistancePage.astro';
import { FEATURED_DRUGS } from '../data/drugAssistance';

export function getStaticPaths() {
  return FEATURED_DRUGS.map((d) => ({ params: { drug: d.slug } }));
}
---

<DrugAssistancePage />
